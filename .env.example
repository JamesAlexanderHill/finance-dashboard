# Postgres (docker-compose.yml exposes it on host port 5332)
DATABASE_URL=postgresql://dev:development@localhost:5332/db
POSTGRES_USER=dev
POSTGRES_PASSWORD=development
POSTGRES_DB=db

# Better Auth
# Generate a 32+ char secret, e.g. `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace-me-with-a-32-char-secret
# Base URL of the app (used to build magic-link URLs and as the passkey origin)
BETTER_AUTH_URL=http://localhost:3000
# Passkey relying-party ID — the registrable domain (no scheme/port).
# Use your apex domain in production, e.g. example.com
PASSKEY_RP_ID=localhost
